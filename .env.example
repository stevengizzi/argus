# Argus Environment Variables
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to git — it's in .gitignore

# Alpaca API Keys
# Get these from: https://app.alpaca.markets/paper/dashboard/overview (paper trading)
# or https://app.alpaca.markets/brokerage/dashboard/overview (live trading)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Health Monitoring Webhooks
# Healthchecks.io ping URL for heartbeat monitoring
# Get from: https://healthchecks.io/ (free tier available)
HEALTHCHECKS_PING_URL=https://hc-ping.com/your-uuid-here

# Discord webhook URL for critical alerts
# Create at: Server Settings > Integrations > Webhooks > New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
