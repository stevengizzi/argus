# Argus Environment Variables
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to git — it's in .gitignore

# Databento API Key (primary market data)
# Get from: https://databento.com/portal
DATABENTO_API_KEY=db-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Interactive Brokers (required for live mode)
IBKR_HOST=127.0.0.1
IBKR_PORT=4002          # 4002 = paper trading, 4001 = live (USE 4002)
IBKR_CLIENT_ID=1

# API Authentication
ARGUS_JWT_SECRET=generate-a-random-string
ARGUS_PASSWORD_HASH=generate-with-bcrypt

# Anthropic API — AI Layer (Sprint 22+)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Alpaca API Keys (strategy incubator only)
# Get these from: https://app.alpaca.markets/paper/dashboard/overview (paper trading)
# or https://app.alpaca.markets/brokerage/dashboard/overview (live trading)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Health Monitoring Webhooks
# Healthchecks.io ping URL for heartbeat monitoring
# Get from: https://healthchecks.io/ (free tier available)
HEALTHCHECKS_PING_URL=https://hc-ping.com/your-uuid-here

# Discord webhook URL for critical alerts
# Create at: Server Settings > Integrations > Webhooks > New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Financial Modeling Prep — pre-market scanning + catalyst news (Sprint 21.7+)
# Get from: https://site.financialmodelingprep.com/ (Starter plan, $22/mo)
FMP_API_KEY=your-fmp-key-here

# Finnhub — supplementary news + analyst recommendations (Sprint 23.5+)
# Get free API key from: https://finnhub.io/register
FINNHUB_API_KEY=your-finnhub-key-here